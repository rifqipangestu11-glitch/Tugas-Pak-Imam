{
  "version": 2,
  "installCommand": "composer install --no-dev --optimize-autoloader && npm install",
  "buildCommand": "php artisan config:cache && php artisan route:cache && npm run build",
  "builds": [
    {
      "src": "api/index.php",
      "use": "@vercel/php"
    }
  ],
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
